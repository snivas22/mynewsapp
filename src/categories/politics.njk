---
layout: base.njk
title: Politics
---

<h2>Politics</h2>
<ul>
{% set items = collections.politics %}
{% for item in items %}
<li>
  <a href="{{ item.url }}"><strong>{{ item.data.title }}</strong></a>
  <div class="meta">{{ item.date | readableDate }} • {{ item.data.source }}</div>
</li>
{% endfor %}
</ul>
