---
layout: base.njk
title: Entertainment
---

<h2>Entertainment</h2>
<ul>
{% set items = collections.entertainment %}
{% for item in items %}
<li>
  <a href="{{ item.url }}"><strong>{{ item.data.title }}</strong></a>
  <div class="meta">{{ item.date }} • {{ item.data.source }}</div>
</li>
{% endfor %}
</ul>
